{% macro default_styles() %}
    <style>
        .flare_paginator__list {
            display: flex;
            flex-flow: row wrap;
            list-style: none;
            padding: 0;
            margin: 0;
            gap: 0;
        }
        .flare_paginator__link {
            display: block;
            padding: .25rem .75rem;
            text-decoration: none;
            border: 1px solid #ddd;
            background-color: #f8f8f8;
            color: #333;
            cursor: pointer;
        }
        .flare_paginator__link:hover {
            background-color: #e9e9e9;
            border-color: #ccc;
        }
        .flare_paginator__item--active .flare_paginator__link {
            background-color: #007bff;
            border-color: #007bff;
            color: #fff;
            cursor: default;
        }
        .flare_paginator__item--disabled .flare_paginator__link {
            background-color: #fff;
            color: #999;
            cursor: not-allowed;
            pointer-events: none;
            text-decoration: none;
        }
    </style>
{% endmacro %}